import { TextEdit } from "std-widgets.slint";
import { Styles } from "../../globals.slint";

export component ResponseBody inherits VerticalLayout {
    in property<string> body;

    Text {
        height: 3%;
        font-size: Styles.font_size;
        text: "Body";
    }

    TextEdit {
        text: root.body;
        read-only: true;
    }
}