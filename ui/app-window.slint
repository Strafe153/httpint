
import { LineEdit, ScrollView } from "std-widgets.slint";
import { Styles } from "globals.slint";
import { Header } from "structs/header.slint";
import { Response } from "structs/response.slint";
import { Loader } from "components/loader.slint";
import { RequestBar } from "components/request/request-bar.slint";
import { RequestHeader } from "components/request/request-header.slint";
import { RequestHeaders } from "components/request/request-headers.slint";
import { RequestBody } from "components/request/request-body.slint";
import { ResponseBar } from "components/response/response-bar.slint";
import { ResponseHeaders } from "components/response/response-headers.slint";
import { ResponseBody } from "components/response/response-body.slint";

export component AppWindow inherits Window {
    min-width: 720px;
    min-height: 400px;
    max-width: 3840px;
    max-height: 2160px;

    private property<string> type: bar.type;
    private property<string> body: bd.body;

    in property<[Header]> headers;
    in property<Response> response;
    in property<bool> is_loading;

    callback send(url: string, type: string, body: string);
    callback add();
    callback edit_name(int, string);
    callback edit_value(int, string);
    callback remove(int);

    ScrollView {
        Loader {
            is_loading: root.is_loading;
        }
        
        VerticalLayout {
            padding: Styles.padding;
            spacing: Styles.spacing;
            visible: !root.is_loading;

            // TODO: move everything request-related into request component,
            // then just loop over headers and remove request-headers component
            bar := RequestBar {
                send(url, type) => root.send(url, type, body);
            }

            RequestHeaders {
                headers: root.headers;
                
                add => root.add();
                edit_name(index, value) => root.edit_name(index, value);
                edit_value(index, value) => root.edit_value(index, value);
                remove(index) => root.remove(index);
            }

            bd := RequestBody {
                type: root.type;
            }

            if response.status-code > 0: VerticalLayout {
                ResponseBar {
                    response: root.response;
                }

                ResponseHeaders {
                    headers: root.response.headers;
                }

                ResponseBody {}
            }
        }
    }
}